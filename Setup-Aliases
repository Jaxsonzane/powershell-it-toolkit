# ============================================================
#  Setup-Aliases.ps1
#  Run as Administrator ONCE to configure all script aliases
#  Update $scriptsPath below before running
# ============================================================

Write-Host "`n=== PowerShell IT Toolkit - Alias Setup ===" -ForegroundColor Cyan

# UPDATE THIS PATH to wherever you cloned/saved the scripts
$scriptsPath = "C:\Users\YOUR_USERNAME\Documents\PowerShell Scripts"

if (-not (Test-Path $scriptsPath)) {
    Write-Host "ERROR: Scripts folder not found at: $scriptsPath" -ForegroundColor Red
    Write-Host "Update the path in this script and re-run." -ForegroundColor Yellow
    exit
}

if (-not (Test-Path $PROFILE)) {
    New-Item -ItemType File -Path $PROFILE -Force | Out-Null
    Write-Host "Created PowerShell profile." -ForegroundColor Green
}

$profileContent = @"
# ============================================================
# IT Toolkit Aliases - auto-generated by Setup-Aliases.ps1
# ============================================================

function morning    { & "$scriptsPath\MorningStartup.ps1" }
function speedboost { & "$scriptsPath\SpeedBoost.ps1" }
function netdiag    { & "$scriptsPath\NetDiag.ps1" }
function netreset   { & "$scriptsPath\NetReset.ps1" }
function netmon     { & "$scriptsPath\NetMonitor.ps1" }
function wifireport { & "$scriptsPath\WiFiReport.ps1" }
function proxychk   { & "$scriptsPath\ProxyChecker.ps1" }
function vpnrepair  { & "$scriptsPath\VPNRepair.ps1" }
function printdiag  { & "$scriptsPath\PrinterDiag.ps1" }
function spooler    { & "$scriptsPath\PrintSpoolerReset.ps1" }
function outlookfix { & "$scriptsPath\OutlookRepair.ps1" }
function slackfix   { & "$scriptsPath\SlackRepair.ps1" }
function browserfix { & "$scriptsPath\BrowserRepair.ps1" }
function chromerm   { & "$scriptsPath\RemoveChrome.ps1" }
function chromein   { & "$scriptsPath\ReinstallChrome.ps1" }
function diskclean  { & "$scriptsPath\DiskCleanup.ps1" }
function wufix      { & "$scriptsPath\WindowsUpdateFix.ps1" }
function crashdiag  { & "$scriptsPath\AppCrashDiag.ps1" }
function profilediag{ & "$scriptsPath\UserProfileDiag.ps1" }
function rdpfix     { & "$scriptsPath\RemoteDesktopFix.ps1" }
function gal        { & "$scriptsPath\GALManager.ps1" }
function mapdrives  { & "$scriptsPath\MapDrives.ps1" }

function scripts {
    Write-Host "`nAvailable IT Toolkit Commands:" -ForegroundColor Cyan
    Write-Host "  morning     - Daily startup routine" -ForegroundColor Green
    Write-Host "  speedboost  - Performance optimization" -ForegroundColor Green
    Write-Host "  netdiag     - Network diagnostics" -ForegroundColor Green
    Write-Host "  netreset    - Reset network stack" -ForegroundColor Green
    Write-Host "  netmon      - Network monitor" -ForegroundColor Green
    Write-Host "  wifireport  - Wi-Fi report" -ForegroundColor Green
    Write-Host "  proxychk    - Proxy checker" -ForegroundColor Green
    Write-Host "  vpnrepair   - VPN repair" -ForegroundColor Green
    Write-Host "  printdiag   - Printer diagnostics" -ForegroundColor Green
    Write-Host "  spooler     - Reset print spooler" -ForegroundColor Green
    Write-Host "  outlookfix  - Repair Outlook" -ForegroundColor Green
    Write-Host "  slackfix    - Repair Slack" -ForegroundColor Green
    Write-Host "  browserfix  - Repair browser" -ForegroundColor Green
    Write-Host "  diskclean   - Disk cleanup" -ForegroundColor Green
    Write-Host "  wufix       - Fix Windows Update" -ForegroundColor Green
    Write-Host "  crashdiag   - App crash diagnostics" -ForegroundColor Green
    Write-Host "  rdpfix      - Fix Remote Desktop" -ForegroundColor Green
    Write-Host "  gal         - GAL manager (Exchange)" -ForegroundColor Green
    Write-Host "  mapdrives   - Map network drives`n" -ForegroundColor Green
}
"@

Set-Content -Path $PROFILE -Value $profileContent -Encoding UTF8
Write-Host "Profile written successfully." -ForegroundColor Green
Write-Host "Restart PowerShell to activate all commands." -ForegroundColor Cyan
Write-Host "`nType 'scripts' to see all available commands.`n" -ForegroundColor Yellow
